generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  image          String?
  phone          String?
  country        String?
  role           UserRole        @default(TOURIST)
  emailVerified  DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  bookings       Booking[]
  communityPosts CommunityPost[]
  guide          Guide?
  photos         Photo[]
  postLikes      PostLike[]
  reviews        Review[]
  stories        TravelStory[]
  trips          Trip[]

  @@map("users")
}

model Guide {
  id              String       @id @default(cuid())
  userId          String       @unique
  name            String
  email           String
  phone           String?
  whatsapp        String?
  bio             String
  city            String
  region          String?
  latitude        Float        @default(9.145)
  longitude       Float        @default(40.489)
  profilePhoto    String?
  coverPhoto      String?
  languages       String[]
  specialties     String[]
  yearsExperience Int          @default(1)
  hasCertificate  Boolean      @default(false)
  hasInsurance    Boolean      @default(false)
  licenseNumber   String?
  verified        Boolean      @default(false)
  active          Boolean      @default(true)
  featured        Boolean      @default(false)
  rating          Float        @default(0)
  reviewCount     Int          @default(0)
  responseTime    String       @default("Within 1 hour")
  totalEarnings   Float        @default(0)
  status          GuideStatus  @default(PENDING)
  appliedAt       DateTime     @default(now())
  approvedAt      DateTime?
  rejectedReason  String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  bookings        Booking[]
  experiences     Experience[]
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews         Review[]

  @@map("guides")
}

model Experience {
  id             String    @id @default(cuid())
  guideId        String
  title          String
  description    String
  category       String
  durationHours  Int
  maxGroupSize   Int       @default(8)
  pricePerPerson Float
  currency       String    @default("USD")
  includes       String[]
  excludes       String[]
  images         String[]
  city           String
  meetingPoint   String?
  languages      String[]
  difficulty     String    @default("Easy")
  bestMonths     String[]
  active         Boolean   @default(true)
  featured       Boolean   @default(false)
  rating         Float     @default(0)
  reviewCount    Int       @default(0)
  totalBookings  Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  bookings       Booking[]
  guide          Guide     @relation(fields: [guideId], references: [id], onDelete: Cascade)
  reviews        Review[]

  @@map("experiences")
}

model Hotel {
  id            String    @id @default(cuid())
  externalId    String    @unique
  name          String
  city          String
  location      String
  description   String
  stars         Int
  pricePerNight Float
  latitude      Float
  longitude     Float
  images        String[]
  amenities     String[]
  affiliateUrl  String
  featured      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  bookings      Booking[]
  reviews       Review[]

  @@map("hotels")
}

model Booking {
  id              String        @id @default(cuid())
  userId          String
  type            BookingType
  status          BookingStatus @default(PENDING)
  guideId         String?
  experienceId    String?
  groupSize       Int           @default(1)
  bookingDate     DateTime?
  hotelId         String?
  checkIn         DateTime?
  checkOut        DateTime?
  nights          Int           @default(1)
  guestCount      Int           @default(1)
  totalAmountUSD  Float
  currency        String        @default("USD")
  paymentProvider String?
  paymentRef      String?
  paidAt          DateTime?
  guestName       String?
  guestEmail      String?
  guestPhone      String?
  specialRequests String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  experience      Experience?   @relation(fields: [experienceId], references: [id])
  guide           Guide?        @relation(fields: [guideId], references: [id])
  hotel           Hotel?        @relation(fields: [hotelId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@map("bookings")
}

model Review {
  id           String      @id @default(cuid())
  userId       String
  rating       Int
  comment      String
  type         String
  hotelId      String?
  guideId      String?
  experienceId String?
  approved     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  experience   Experience? @relation(fields: [experienceId], references: [id])
  guide        Guide?      @relation(fields: [guideId], references: [id])
  hotel        Hotel?      @relation(fields: [hotelId], references: [id])
  user         User        @relation(fields: [userId], references: [id])

  @@map("reviews")
}

model Trip {
  id        String    @id @default(cuid())
  userId    String
  title     String
  summary   String?
  itinerary Json
  duration  Int
  budget    String
  interests String[]
  startDate DateTime?
  totalCost Float?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("trips")
}

model CommunityPost {
  id        String      @id @default(cuid())
  userId    String
  text      String
  imageUrl  String?
  location  String?
  tag       String      @default("Tips")
  likes     Int         @default(0)
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  postLikes PostLike[]
  replies   PostReply[]

  @@map("community_posts")
}

model PostReply {
  id         String        @id @default(cuid())
  postId     String
  authorName String
  text       String
  likes      Int           @default(0)
  createdAt  DateTime      @default(now())
  post       CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("post_replies")
}

model PostLike {
  id        String        @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@map("post_likes")
}

model Photo {
  id           String   @id @default(cuid())
  userId       String
  url          String
  cloudinaryId String
  caption      String?
  location     String?
  destination  String?
  tags         String[]
  likes        Int      @default(0)
  approved     Boolean  @default(true)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@map("photos")
}

model TravelStory {
  id           String   @id @default(cuid())
  userId       String
  title        String
  content      String
  coverImage   String?
  destinations String[]
  duration     Int
  budget       Float?
  rating       Float?
  likes        Int      @default(0)
  views        Int      @default(0)
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@map("travel_stories")
}

model AffiliateClick {
  id        String   @id @default(cuid())
  hotelId   String
  userId    String?
  source    String
  url       String
  ipHash    String?
  createdAt DateTime @default(now())

  @@map("affiliate_clicks")
}

enum UserRole {
  TOURIST
  GUIDE
  ADMIN
}

enum GuideStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum BookingType {
  GUIDE_EXPERIENCE
  HOTEL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  REFUNDED
}
