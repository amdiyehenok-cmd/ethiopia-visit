# ── 1. AI (Groq — FREE, 14,400 req/day) ───────────────────
# Sign up FREE at: https://console.groq.com → API Keys → Create Key
# Model used: llama-3.3-70b-versatile (smarter than Gemini Flash)
GROQ_API_KEY=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

# ── 2. Database (Neon PostgreSQL — free tier works) ───────
# Get from: https://neon.tech → New Project → Copy connection string
DATABASE_URL=postgresql://authenticator:npg_rvLT0sFICxo3@ep-wild-frost-agao67sn-pooler.c-2.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# Direct connection — required by Prisma for migrations
DIRECT_URL=postgresql://authenticator:npg_rvLT0sFICxo3@ep-wild-frost-agao67sn.c-2.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── 3. Auth ───────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
