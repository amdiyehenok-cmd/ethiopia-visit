# ── 6. Photos (Unsplash) ──────────────────────────────────
# Get from: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=IfKkVeG-NYhBhXUDfrJrzlcI8HWRvUKjwQ8e6PvIwyo

# ── 7. Stripe (International Card Payments) ───────────────
# Get from: https://dashboard.stripe.com → Developers → API Keys
# Use sk_test_ / pk_test_ for development
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── 8. Chapa (Ethiopia ETB Payments) ──────────────────────
# Get from: https://dashboard.chapa.co → Settings → API Keys
# Free sandbox available instantly at: https://developer.chapa.co
CHAPA_SECRET_KEY=CHASECK_TEST-...
NEXT_PUBLIC_CHAPA_PUBLIC_KEY=CHAPUBK_TEST-...

# ── 9. Telebirr (Ethio Telecom Mobile Money) ──────────────
# Apply at: https://developer.ethiotelecom.et
# Requires business registration in Ethiopia
TELEBIRR_APP_ID=your-app-id
TELEBIRR_APP_KEY=your-app-key
TELEBIRR_PUBLIC_KEY=your-rsa-public-key
TELEBIRR_SHORT_CODE=your-short-code

# ── 10. PayPal ────────────────────────────────────────────
# Get from: https://developer.paypal.com
NEXT_PUBLIC_PAYPAL_EMAIL=your-paypal-business-email@example.com

# ── 11. Booking.com Affiliate ─────────────────────────────
# Apply at: https://join.booking.com (takes 1-2 days approval)
BOOKING_AFFILIATE_ID=your-affiliate-id

# ── 12. Google AdSense ────────────────────────────────────
# Apply at: https://adsense.google.com (takes 1-14 days)
# Format: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-

# ── 13. Google Analytics ──────────────────────────────────
# Get from: https://analytics.google.com → Create property
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-

# ── 14. App URLs ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# After deploy: NEXT_PUBLIC_APP_URL=https://ethiopia-visit.vercel.app

# ── FREE APIs (no key required) ───────────────────────────
# ExchangeRate: https://api.exchangerate-api.com (free tier, no key)
# Overpass API: https://overpass-api.de (OpenStreetMap, no key)
# Leaflet/OSM Maps: built-in, no key
# Web Speech API: browser built-in, no key
# Geolocation API: browser built-in, no key

# ── QUICK START PRIORITY ──────────────────────────────────
# To get the site running immediately, you ONLY need:
# 1. GEMINI_API_KEY (free at aistudio.google.com)
# 2. DATABASE_URL (free at neon.tech)
# 3. NEXTAUTH_SECRET (generate locally)
# Everything else is optional / progressive enhancement.

# ── Cloudinary Unsigned Upload Preset ─────────────────────
# In Cloudinary Dashboard → Settings → Upload → Add upload preset
# Set it as 'unsigned', name it 'ethiopia_ugc'
CLOUDINARY_UPLOAD_PRESET=ethiopia_ugc
